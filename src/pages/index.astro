---
import Base from '../layouts/Base.astro';
---

<Base title="Wonderfilled, Inc. — wonderfilled.games">

  <!-- Hero -->
  <section class="hero" id="home">
    <div class="hero-bg"></div>
    <div class="hero-grid"></div>
    <div class="hero-ornament"></div>
    <div class="hero-content">
      <p class="hero-eyebrow">Wonderfilled, Inc. &nbsp;·&nbsp; wonderfilled.games</p>
      <h1 class="hero-title">Worlds<br>Worth<br><em>Believing.</em></h1>
      <div class="hero-rule"></div>
      <p class="hero-sub">A transmedia studio for the age of infinite narrative.</p>
      <p class="hero-body">
        We design games, stories, and experiences that live at the intersection of play, myth, and technology — built to endure.
      </p>
      <div class="hero-ctas">
        <a class="btn-primary" href="/projects">Explore Our Worlds</a>
        <a class="btn-ghost" href="/about">Our Mission</a>
      </div>
    </div>
    <div class="hero-scroll">
      <div class="scroll-line"></div>
      Scroll
    </div>
  </section>

  <!-- Marquee -->
  <div class="marquee-wrap">
    <div class="marquee-track">
      <div class="marquee-item">Transmedia Design <span class="marquee-sep"></span></div>
      <div class="marquee-item">Narrative Architecture <span class="marquee-sep"></span></div>
      <div class="marquee-item">Game Publishing <span class="marquee-sep"></span></div>
      <div class="marquee-item">Themed Entertainment <span class="marquee-sep"></span></div>
      <div class="marquee-item">Interactive Worlds <span class="marquee-sep"></span></div>
      <div class="marquee-item">Academic Research <span class="marquee-sep"></span></div>
      <div class="marquee-item">IP Development <span class="marquee-sep"></span></div>
      <div class="marquee-item">Wonderfilled, Inc. <span class="marquee-sep"></span></div>
      <div class="marquee-item">Transmedia Design <span class="marquee-sep"></span></div>
      <div class="marquee-item">Narrative Architecture <span class="marquee-sep"></span></div>
      <div class="marquee-item">Game Publishing <span class="marquee-sep"></span></div>
      <div class="marquee-item">Themed Entertainment <span class="marquee-sep"></span></div>
      <div class="marquee-item">Interactive Worlds <span class="marquee-sep"></span></div>
      <div class="marquee-item">Academic Research <span class="marquee-sep"></span></div>
      <div class="marquee-item">IP Development <span class="marquee-sep"></span></div>
      <div class="marquee-item">Wonderfilled, Inc. <span class="marquee-sep"></span></div>
    </div>
  </div>

  <!-- About -->
  <section id="about">
    <div class="about-stats">
      <div class="section-eyebrow">About the Studio</div>
      <h2 class="section-title">Where <em>Myth</em><br>Meets Medium.</h2>
      <div class="about-stat-grid">
        <div class="about-stat">
          <div class="stat-num">25+</div>
          <div class="stat-label">Years in Industry</div>
        </div>
        <div class="about-stat">
          <div class="stat-num">AAA</div>
          <div class="stat-label">Game Credits</div>
        </div>
        <div class="about-stat">
          <div class="stat-num">THEA</div>
          <div class="stat-label">Award Winner</div>
        </div>
        <div class="about-stat">
          <div class="stat-num">∞</div>
          <div class="stat-label">Worlds to Build</div>
        </div>
      </div>
    </div>
    <div class="about-text">
      <p>Wonderfilled, Inc. is a <strong>transmedia studio and publisher</strong> founded by Stephen Erin Dinehart IV — the designer who coined the term <strong>Narrative Designer</strong> in 2006 and helped define the discipline now standard across the industry.</p>
      <p>From AAA titles to Super Nintendo World, from GiantLands to <em>Emperor of the Cherokee</em> — we build worlds with depth, intention, and longevity. Our properties are designed to transcend platform: <strong>games, novels, experiences, and theme parks</strong> that share one mythology.</p>
      <p>We operate at the frontier where <strong>ancient story meets emergent technology</strong> — and we believe that the studios of the future are also the guardians of myth.</p>
      <a class="btn-ghost" href="/about" style="display:inline-block; margin-top: 1rem;">Partner With Us →</a>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects">
    <div class="projects-header">
      <div>
        <div class="section-eyebrow">Games &amp; Projects</div>
        <h2 class="section-title">Our <em>Worlds.</em></h2>
      </div>
      <a class="btn-ghost" href="/projects">View All Projects →</a>
    </div>
    <div class="projects-grid">
      <a class="project-card card-featured" href="/projects/giantlands">
        <div class="card-num">01</div>
        <span class="card-tag">Flagship Universe</span>
        <h3 class="card-title">GiantLands</h3>
        <p class="card-subtitle">Tuskaloosa's Reckoning · The Broken Road · Fifth Age Codex</p>
        <p class="card-body">A 30-year transmedia universe rooted in ancestral American myth. Tabletop RPG, novels, adventure modules, and a blueprint for a landmark themed experience at Aztalan State Park.</p>
        <div class="card-formats">
          <span class="format-pill active">Tabletop RPG</span>
          <span class="format-pill active">Novels</span>
          <span class="format-pill active">Adventure Modules</span>
          <span class="format-pill">Theme Park</span>
        </div>
        <span class="card-arrow">↗</span>
      </a>
      <div class="project-card">
        <div class="card-num">02</div>
        <span class="card-tag">Ancient Myth · Epic Universe</span>
        <h3 class="card-title">Tablet of Destinies</h3>
        <p class="card-subtitle">Throne of Ninurta · Rise of Marduk</p>
        <p class="card-body">An epic transmedia universe drawn from the oldest stories ever told — Sumerian and Akkadian myth reborn. Begins with the opera <em>Throne of Ninurta</em> and expands through <em>Rise of Marduk</em> into feature film, novels, and an original app.</p>
        <div class="card-formats">
          <span class="format-pill active">Opera</span>
          <span class="format-pill">Feature Film</span>
          <span class="format-pill">Novels</span>
          <span class="format-pill">App</span>
        </div>
        <span class="card-arrow">↗</span>
      </div>
      <a class="project-card" href="/projects/emperor">
        <div class="card-num">03</div>
        <span class="card-tag">Historical Novel</span>
        <h3 class="card-title">Emperor of the Cherokee</h3>
        <p class="card-subtitle">Published April 3, 2026</p>
        <p class="card-body">A sweeping four-voice historical novel published on the 296th anniversary of Moytoy's coronation. The hidden history of a Cherokee empire — told in Testimony, Witness, Record, and Reflection.</p>
        <div class="card-formats">
          <span class="format-pill active">Novel</span>
          <span class="format-pill">Audiobook</span>
        </div>
        <span class="card-arrow">↗</span>
      </a>
      <a class="project-card" href="/services">
        <div class="card-num">04</div>
        <span class="card-tag">Client Work</span>
        <h3 class="card-title">For Hire</h3>
        <p class="card-subtitle">Rovio · Evermore Park · Studio 11</p>
        <p class="card-body">We bring our transmedia craft to visionary partners. Recent work includes Rovio/Angry Birds, Evermore Park, The Dungeon Hobbyshop Museum, and Studio 11's <em>Stage11</em> — a playable music metaverse featuring David Guetta and Snoop Dogg.</p>
        <div class="card-formats">
          <span class="format-pill active">Narrative Design</span>
          <span class="format-pill active">Transmedia</span>
          <span class="format-pill active">Experience Design</span>
          <span class="format-pill active">Metaverse</span>
        </div>
        <span class="card-arrow">↗</span>
      </a>
    </div>
  </section>

  <!-- Services -->
  <section id="services">
    <div style="max-width: 600px;">
      <div class="section-eyebrow">Services</div>
      <h2 class="section-title">What We <em>Offer.</em></h2>
    </div>
    <div class="services-grid">
      <div class="service-item">
        <div class="service-icon">01</div>
        <h3 class="service-title">Narrative Design &amp; Consulting</h3>
        <p class="service-body">From AAA to indie — story architecture, world bible development, character systems, and transmedia strategy from the designer who named the discipline.</p>
      </div>
      <div class="service-item">
        <div class="service-icon">02</div>
        <h3 class="service-title">Transmedia IP Development</h3>
        <p class="service-body">We build original intellectual properties designed to expand across games, novels, film, and physical experiences — structured for longevity and licensing.</p>
      </div>
      <div class="service-item">
        <div class="service-icon">03</div>
        <h3 class="service-title">Themed Entertainment Design</h3>
        <p class="service-body">Concept development, narrative experience design, and creative direction for theme parks, immersive attractions, and branded worlds. THEA Award level craft.</p>
      </div>
      <div class="service-item">
        <div class="service-icon">04</div>
        <h3 class="service-title">Publishing &amp; Production</h3>
        <p class="service-body">Game publishing, tabletop RPG production, novel development, and audiobook production — from manuscript to market under the Wonderfilled banner.</p>
      </div>
      <div class="service-item">
        <div class="service-icon">05</div>
        <h3 class="service-title">Speaking &amp; Academic</h3>
        <p class="service-body">Keynotes, workshops, and institutional partnerships. TEDxTransmedia Geneva. Harvard Business School. RiseUp Cairo. Bristol VR Lab. We bring the frontier to your stage.</p>
      </div>
      <div class="service-item">
        <div class="service-icon">06</div>
        <h3 class="service-title">AI &amp; Emerging Media</h3>
        <p class="service-body">Strategic consulting on generative AI, synthetic media, deepfakes, and the ethics of emergent storytelling technologies. Research-backed, industry-tested.</p>
      </div>
    </div>
  </section>

  <!-- News -->
  <section id="news">
    <div class="news-header">
      <div>
        <div class="section-eyebrow">News &amp; Updates</div>
        <h2 class="section-title">Latest <em>Dispatches.</em></h2>
      </div>
      <a class="btn-ghost" href="/news">All News →</a>
    </div>
    <div class="news-list">
      <a class="news-item" href="/news/emperor-publishes">
        <div class="news-date">APR 03, 2026</div>
        <div class="news-title">Emperor of the Cherokee Publishes on the 296th Anniversary of Moytoy's Coronation</div>
        <span class="news-cat">Publishing</span>
      </a>
      <a class="news-item" href="/news/unreal-partnership">
        <div class="news-date">MAR 2026</div>
        <div class="news-title">Wonderfilled Secures University of Tampa Unreal Academic Partnership with Epic Games</div>
        <span class="news-cat">Partnership</span>
      </a>
      <a class="news-item" href="/news/giantlands-launch">
        <div class="news-date">NOV 2025</div>
        <div class="news-title">GiantLands Launch: Tuskaloosa's Reckoning, The Broken Road &amp; Fifth Age Codex</div>
        <span class="news-cat">Games</span>
      </a>
      <a class="news-item" href="/news/teaas-iaapa">
        <div class="news-date">NOV 2025</div>
        <div class="news-title">TEAAS @ IAAPA: Fantasy-Reality Tension Maps Research Presentation</div>
        <span class="news-cat">Research</span>
      </a>
      <a class="news-item" href="/news/spaghetti-strategy">
        <div class="news-date">2025</div>
        <div class="news-title">"The Spaghetti Strategy" Published in IEEE Computer</div>
        <span class="news-cat">Publication</span>
      </a>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact">
    <div class="contact-inner">
      <div class="section-eyebrow" style="justify-content: center;">Contact</div>
      <h2 class="section-title" style="font-size: clamp(3rem, 7vw, 6rem);">Let's Build<br><em>Something.</em></h2>
      <p class="contact-tagline">Whether you're a studio, publisher, park, or storyteller — we want to hear about your world.</p>
      <div style="margin-top: 3rem; display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap;">
        <a class="btn-primary" href="/contact">Send a Message</a>
        <a class="btn-ghost" href="/contact#press-kit">Download Press Kit</a>
      </div>
    </div>
  </section>

</Base>
