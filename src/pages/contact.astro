---
import Base from '../layouts/Base.astro';
---

<Base
  title="Contact — Wonderfilled, Inc."
  description="Get in touch with Wonderfilled, Inc. for partnerships, licensing, consulting, press inquiries, or speaking engagements."
>

  <div class="page-hero">
    <div class="page-hero-eyebrow">Contact</div>
    <h1 class="page-hero-title">Let's Build<br><em>Something.</em></h1>
    <p class="page-hero-sub">Whether you're a studio, publisher, park, or storyteller — we want to hear about your world.</p>
  </div>

  <!-- Form -->
  <section class="inner-section" style="background: var(--ink);">
    <div style="max-width: 700px; margin: 0 auto;">
      <div class="section-eyebrow">Send a Message</div>
      <h2 class="section-title" style="font-size: clamp(1.8rem, 3vw, 2.8rem); margin-bottom: 3rem;">Tell Us About <em>Your World.</em></h2>

      <form name="contact" method="POST" data-netlify="true" class="contact-form" style="max-width: 100%;">
        <input type="hidden" name="form-name" value="contact">
        <div class="form-group">
          <label class="form-label" for="name">Name</label>
          <input class="form-input" type="text" id="name" name="name" required placeholder="Your name">
        </div>
        <div class="form-group">
          <label class="form-label" for="email">Email</label>
          <input class="form-input" type="email" id="email" name="email" required placeholder="your@email.com">
        </div>
        <div class="form-group">
          <label class="form-label" for="org">Organization</label>
          <input class="form-input" type="text" id="org" name="org" placeholder="Studio, publisher, institution, or your own name">
        </div>
        <div class="form-group">
          <label class="form-label" for="subject">Subject</label>
          <select class="form-input form-select" id="subject" name="subject">
            <option value="">Select a topic</option>
            <option value="partnership">Partnership / Collaboration</option>
            <option value="licensing">IP Licensing</option>
            <option value="consulting">Consulting / Services</option>
            <option value="press">Press Inquiry</option>
            <option value="speaking">Speaking Engagement</option>
            <option value="publishing">Publishing Inquiry</option>
            <option value="academic">Academic Partnership</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="message">Message</label>
          <textarea class="form-textarea" id="message" name="message" required placeholder="Tell us about your world, your project, or what you're hoping to build together..."></textarea>
        </div>
        <button type="submit" class="btn-primary" style="border: none; cursor: crosshair; width: 100%; padding: 1.2rem; font-size: 0.65rem;">
          Send Message
        </button>
      </form>
    </div>
  </section>

  <!-- Press Kit -->
  <section class="inner-section" style="background: var(--ink2); text-align: center;" id="press-kit">
    <div class="section-eyebrow" style="justify-content: center;">Press</div>
    <h2 class="section-title" style="font-size: clamp(2rem, 4vw, 3.5rem); margin-bottom: 2rem;">Press <em>Kit.</em></h2>
    <p style="font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 300; font-style: italic; color: var(--mist2); max-width: 500px; margin: 0 auto 3rem; line-height: 1.6;">
      Studio logos, founder bio, project artwork, and brand guidelines — formatted for media use.
    </p>
    <a class="btn-ghost" href="#">Download Press Kit</a>
    <p style="margin-top: 2rem; font-size: 0.58rem; letter-spacing: 0.15em; color: var(--text-body);">
      For urgent press inquiries, contact us directly via the form above.
    </p>
  </section>

</Base>
