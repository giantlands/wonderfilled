---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Wonderfilled, Inc. — A transmedia studio for the age of infinite narrative. Games, novels, experiences, and theme parks that share one mythology.',
  ogImage = '/og/default.jpg',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Bebas+Neue&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>
  <canvas id="pixie-dust" style="position:fixed;inset:0;z-index:9999;pointer-events:none;"></canvas>
  <Nav />
  <slot />
  <Footer />
  <script>
    const canvas = document.getElementById('pixie-dust');
    const ctx = canvas.getContext('2d');
    let w, h;
    const particles = [];
    const COUNT = 60;

    function resize() {
      w = canvas.width = window.innerWidth;
      h = canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    function rand(a, b) { return Math.random() * (b - a) + a; }

    for (let i = 0; i < COUNT; i++) {
      particles.push({
        x: rand(0, w),
        y: rand(0, h),
        r: rand(1, 2.5),
        dx: rand(-0.15, 0.15),
        dy: rand(-0.3, -0.08),
        drift: rand(0.3, 1.2),
        phase: rand(0, Math.PI * 2),
        speed: rand(0.003, 0.008),
        alpha: rand(0.15, 0.5),
        pulse: rand(0.01, 0.025),
        hue: rand(38, 52),
      });
    }

    const stars = [];
    let nextStar = rand(2000, 6000);

    function spawnStar() {
      stars.push({
        x: rand(w * 0.1, w * 0.9),
        y: -20,
        angle: rand(0.15, 0.5) * (Math.random() < 0.5 ? 1 : -1),
        speed: rand(4, 8),
        life: 1,
        decay: rand(0.006, 0.012),
        len: rand(60, 140),
        hue: rand(38, 55),
      });
      nextStar = rand(3000, 8000);
    }

    let lastTime = 0;
    let starTimer = rand(1000, 3000);

    function draw(t) {
      const dt = t - lastTime;
      lastTime = t;
      ctx.clearRect(0, 0, w, h);

      for (const p of particles) {
        p.phase += p.speed;
        p.x += p.dx + Math.sin(p.phase) * p.drift * 0.3;
        p.y += p.dy;

        const flicker = 0.5 + 0.5 * Math.sin(p.phase * 3);
        const a = p.alpha * (0.4 + 0.6 * flicker);

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = `hsla(${p.hue}, 60%, 65%, ${a})`;
        ctx.fill();

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r * 3, 0, Math.PI * 2);
        const g = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r * 3);
        g.addColorStop(0, `hsla(${p.hue}, 70%, 70%, ${a * 0.35})`);
        g.addColorStop(1, `hsla(${p.hue}, 70%, 70%, 0)`);
        ctx.fillStyle = g;
        ctx.fill();

        if (p.y < -10) { p.y = h + 10; p.x = rand(0, w); }
        if (p.x < -10) p.x = w + 10;
        if (p.x > w + 10) p.x = -10;
      }

      starTimer -= dt;
      if (starTimer <= 0) spawnStar();

      for (let i = stars.length - 1; i >= 0; i--) {
        const s = stars[i];
        s.x += Math.sin(s.angle) * s.speed;
        s.y += Math.cos(s.angle) * s.speed;
        s.life -= s.decay;
        if (s.life <= 0) { stars.splice(i, 1); continue; }

        const tailX = s.x - Math.sin(s.angle) * s.len * s.life;
        const tailY = s.y - Math.cos(s.angle) * s.len * s.life;

        const sg = ctx.createLinearGradient(s.x, s.y, tailX, tailY);
        sg.addColorStop(0, `hsla(${s.hue}, 80%, 85%, ${s.life * 0.9})`);
        sg.addColorStop(0.3, `hsla(${s.hue}, 70%, 70%, ${s.life * 0.5})`);
        sg.addColorStop(1, `hsla(${s.hue}, 60%, 60%, 0)`);

        ctx.beginPath();
        ctx.moveTo(s.x, s.y);
        ctx.lineTo(tailX, tailY);
        ctx.strokeStyle = sg;
        ctx.lineWidth = 1.5 * s.life;
        ctx.stroke();

        ctx.beginPath();
        ctx.arc(s.x, s.y, 2.5 * s.life, 0, Math.PI * 2);
        const hg = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, 6 * s.life);
        hg.addColorStop(0, `hsla(${s.hue}, 80%, 90%, ${s.life * 0.8})`);
        hg.addColorStop(1, `hsla(${s.hue}, 80%, 90%, 0)`);
        ctx.fillStyle = hg;
        ctx.fill();

        if (s.y > h + 20 || s.x < -50 || s.x > w + 50) {
          stars.splice(i, 1);
        }
      }

      requestAnimationFrame(draw);
    }
    requestAnimationFrame(draw);
  </script>
</body>
</html>
