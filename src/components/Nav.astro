---
const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/services', label: 'Services' },
  { href: '/news', label: 'News' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<nav>
  <a class="nav-logo" href="/">Wonder<span>filled</span></a>
  <ul class="nav-links">
    {navLinks.map(link => (
      <li>
        <a
          href={link.href}
          class={currentPath.startsWith(link.href) ? 'active' : ''}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
  <a class="nav-cta" href="/contact">Work With Us</a>
</nav>

<style>
  .nav-links a.active {
    color: var(--gold);
  }
</style>
